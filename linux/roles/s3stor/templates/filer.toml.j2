# SeaweedFS Filer Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

#[leveldb2]
#dir = "{{ s3stor_data_dir }}/filer/leveldb2"

[redis_cluster2]
enabled = true
addresses = [{% for host in groups['metadb_nodes'] %}"{{ hostvars[host]['ansible_host'] }}:6379"{% if not loop.last %},{% endif %}{% endfor %}]
# Password for Redis authentication (optional)
{% if s3stor_metadb_password is defined %}
password = "{{ s3stor_metadb_password }}"
{% else %}
# password = ""
{% endif %}
database = 0


[master]
metaNodes = [
{% for host in groups['s3stor_masters'] %}
  "{{ hostvars[host]['ansible_host'] | default(hostvars[host]['ansible_default_ipv4']['address'] | default(host)) }}:{{ s3stor_master_grpc_port }}"{% if not loop.last %}, {% endif %}
{% endfor %}
]

[s3]
domain = "{{ s3stor_domain }}"
# For production, consider configuring credentials:
# access_key = ""
# secret_key = ""

[cluster]
# Filer cluster settings
nodes = [{% for host in groups['s3stor_filers'] %}"{{ hostvars[host]['ansible_host'] }}:{{ s3stor_filer_port }}"{% if not loop.last %},{% endif %}{% endfor %}]

[filer]
# Filer settings
dirCacheCapacity = "1000000"
dirCacheExpiration = "5m"
maxMB = "32"
hashSize = "1048576"
concurrentStart = "true"

[grpc]
# gRPC settings
dialTimeout = "10s"
keepAliveTime = "30s"
keepAliveTimeout = "10s"

[metrics]
# Prometheus metrics
enabled = true
port = {{ s3stor_filer_metrics_port }}
