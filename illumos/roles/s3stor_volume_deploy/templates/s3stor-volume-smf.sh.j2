#!/sbin/sh

. /lib/svc/share/smf_include.sh

# S3Stor Service Configuration
# Generated by Ansible for {{ inventory_hostname }}

/opt/s3stor/bin/s3stor volume \
  -ip.bind=0.0.0.0 \
  -mserver="{{ hostvars[groups['front_nodes'][0]]['ansible_host'] }}:9333,{{ hostvars[groups['front_nodes'][1]]['ansible_host'] }}:9333,{{ hostvars[groups['front_nodes'][2]]['ansible_host'] }}:9333" \
  -port={{ s3stor_volume_port }} \
  -dir={{ s3stor_volume_data_directory }} \
  -max={{ s3stor_volume_max_volumes }} \
  -dataCenter={{ s3stor_volume_datacenter }} \
  -rack={{ s3stor_volume_rack }} \
  -compactionMBps={{ s3stor_volume_compaction_speed }} \
  -fileSizeLimitMB={{ s3stor_volume_file_size_limit }} \
  -metricsPort={{ s3stor_volume_metrics_port }} &

exit $SMF_EXIT_OK
