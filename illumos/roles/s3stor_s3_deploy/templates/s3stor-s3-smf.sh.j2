#!/sbin/sh

. /lib/svc/share/smf_include.sh

# S3Stor Service Configuration
# Generated by Ansible for {{ inventory_hostname }}

cd /opt/s3stor/bin/ && ./s3stor filer \
  -ip={{ ansible_host }} \
  -ip.bind=0.0.0.0 \
  -master="{{ hostvars[groups['front_nodes'][0]]['ansible_host'] }}:9333,{{ hostvars[groups['front_nodes'][1]]['ansible_host'] }}:9333,{{ hostvars[groups['front_nodes'][2]]['ansible_host'] }}:9333" \
  -port={{ s3stor_s3_filer_port }} \
  -defaultReplicaPlacement={{ s3stor_s3_default_replica_placement }} \
  -metricsPort={{ s3stor_s3_filer_metrics_port }} \
  -s3 \
  -s3.config={{ s3stor_s3_config }} \
  -s3.port={{ s3stor_s3_port }} \
  -s3.metricsPort={{ s3stor_s3_metrics_port }} &

exit $SMF_EXIT_OK
