# SeaweedFS Filer Configuration
# Generated by Ansible for {{ inventory_hostname }}

[redis_cluster2]
enabled = true
addresses = [{% for host in groups['metadb_nodes'] %}"{{ hostvars[host]['ansible_host'] }}:6379"{% if not loop.last %},{% endif %}{% endfor %}]
# Password for Redis authentication (optional)
{% if s3stor_metadb_password is defined %}
password = "{{ s3stor_metadb_password }}"
{% else %}
# password = ""
{% endif %}
database = 0

[cluster]
# Filer cluster settings
nodes = [{% for host in groups['front_nodes'] %}"{{ hostvars[host]['ansible_host'] }}:{{ s3stor_s3_filer_port }}"{% if not loop.last %},{% endif %}{% endfor %}]

[filer]
# Filer settings
dirCacheCapacity = "1000000"
dirCacheExpiration = "5m"
maxMB = "32"
hashSize = "1048576"
concurrentStart = "true"

[grpc]
# gRPC settings
dialTimeout = "10s"
keepAliveTime = "30s"
keepAliveTimeout = "10s"

[metrics]
# Prometheus metrics
enabled = true
port = {{ s3stor_s3_filer_metrics_port }}
