#!/sbin/sh

. /lib/svc/share/smf_include.sh

# S3Stor Service Configuration
# Generated by Ansible for {{ inventory_hostname }}

/opt/s3stor/bin/s3stor master \
  -ip={{ ansible_host }} \
  -ip.bind=0.0.0.0 \
  -mdir /opt/s3stor/data \
  -peers={{ hostvars[groups['front_nodes'][0]]['ansible_host'] }}:9333,{{ hostvars[groups['front_nodes'][1]]['ansible_host'] }}:9333,{{ hostvars[groups['front_nodes'][2]]['ansible_host'] }}:9333 \
  -defaultReplication={{ s3stor_default_replication }} \
  -garbageThreshold=0.3 \
  -volumeSizeLimitMB={{ s3stor_default_volume_size }} \
  -metricsPort={{ s3stor_master_metrics_port }} &

exit $SMF_EXIT_OK
