<?xml version="1.0"?>
<!--
    DO NOT EDIT THIS FILE.  Use zonecfg(8) instead.
    Generated by Ansible for {{ inventory_hostname }}
-->
<!DOCTYPE zone PUBLIC "-//Sun Microsystems Inc//DTD Zones//EN" "file:///usr/share/lib/xml/dtd/zonecfg.dtd.1">
<zone name="{{ metadb_zone_name }}" 
      zonepath="{{ metadb_zone_path }}" 
      autoboot="{{ metadb_zone_autoboot | lower }}" 
      brand="{{ metadb_zone_brand }}" 
      ip-type="exclusive" 
      debugid="10" 
      limitpriv="default">
  <attr name="kernel-version" type="string" value="{{ metadb_kernel_version }}"/>
  <attr name="resolvers" type="string" value="{{ metadb_resolver }}"/>
  <network allowed-address="{{ metadb_allowed_address }}" 
           physical="{{ metadb_physical_nic }}" 
           defrouter="{{ metadb_defrouter }}" 
           mac-addr="{{ metadb_mac_addr }}" 
           global-nic="{{ metadb_global_nic }}"/>
</zone>
